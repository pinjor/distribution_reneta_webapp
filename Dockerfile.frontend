FROM node:20-alpine

WORKDIR /app

# Install dependencies for better caching
COPY package*.json ./
RUN npm ci

# Copy application code
COPY . .

# Ensure entrypoint uses Unix line endings and is readable
RUN sed -i 's/\r$//' docker-entrypoint.frontend.sh

# Expose port
EXPOSE 8080

ENTRYPOINT ["sh", "docker-entrypoint.frontend.sh"]

