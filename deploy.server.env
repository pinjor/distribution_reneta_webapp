# Host port overrides for shared servers (avoids compose "ports merge" appending two mappings).
# Usage on server:
#   docker compose --env-file deploy.server.env -f docker-compose.yml -f docker-compose.server.yml up -d --build
POSTGRES_HOST_PORT=55433
REDIS_HOST_PORT=6390
NGINX_HTTP_PORT=8081
FRONTEND_HOST_PORT=8090
